# ImpactMojo Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit .env — it is git-ignored.

# Supabase project credentials (from https://app.supabase.com → Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# HMAC secret used to sign premium resource JWTs
# Must match RESOURCE_TOKEN_SECRET in each Netlify resource site
RESOURCE_TOKEN_SECRET=generate-a-strong-random-secret-here

# Netlify deploy tokens (one per premium resource site)
# NETLIFY_AUTH_TOKEN=your-netlify-token

# ── LLM Provider Configuration ──────────────────────────────────────
# The game-agent Edge Function supports multiple LLM providers.
# Set API keys for the providers you want to use. The function will
# try them in priority order and fall back through the chain.
#
# Provider priority (comma-separated, cheapest first by default):
# LLM_PROVIDER=deepseek,groq,gemini,together,openai
#
# Set keys for providers you want to enable (only set the ones you use):
# DEEPSEEK_API_KEY=your-deepseek-key       # ~₹0.50/1K sessions, near GPT-4 quality
# GROQ_API_KEY=your-groq-key               # Free tier (rate-limited), very fast
# GEMINI_API_KEY=your-gemini-key            # Free tier available, good quality
# TOGETHER_API_KEY=your-together-key        # ~₹1-3/1K sessions, reliable
# OPENAI_API_KEY=your-openai-key            # Premium fallback (~₹1/session)
# ANTHROPIC_API_KEY=your-anthropic-key      # Premium
#
# Legacy single-provider config (still works as final fallback):
# LLM_API_KEY=your-api-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
