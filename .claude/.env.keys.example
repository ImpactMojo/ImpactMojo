# ImpactMojo API Keys
# Copy this file to .env.keys and fill in your values
# .env.keys is gitignored — never commit actual keys

# Required
GITHUB_PAT=ghp_your_github_personal_access_token
SUPABASE_PAT=sbp_your_supabase_access_token
NETLIFY_PAT=your_netlify_personal_access_token

# Content & AI tools
GAMMA_API_KEY=your_gamma_api_key
GEMINI_API_KEY=your_gemini_api_key
NAPKIN_API_KEY=your_napkin_api_key
GROK_API_KEY=your_grok_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
SARVAM_API_KEY=your_sarvam_api_key
